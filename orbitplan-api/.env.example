PORT=4000
# Structured logs: debug | info | warn | error (default: debug in dev, info in prod)
# LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbitplan?schema=public
ADMIN_EMAIL=admin@orbitplan.local
ADMIN_PASSWORD=OrbitPlanAdmin123!
SESSION_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
TRANSCRIPTION_PROVIDER=mock
ANALYSIS_PROVIDER=mock
CHAT_PROVIDER=mock
AI_TIMEOUT_MS=180000
# OPENAI_API_KEY=your_key_here
JIRA_CLIENT_ID=your_atlassian_oauth_client_id
JIRA_CLIENT_SECRET=your_atlassian_oauth_client_secret
JIRA_REDIRECT_URI=http://localhost:4000/api/integrations/jira/callback
ZOOM_CLIENT_ID=oKoQUshQfSEBhSCbLfnSg
ZOOM_CLIENT_SECRET=G4BKGSzCSsCF6axhFjWc0SSubW3MgLOB
ZOOM_REDIRECT_URI=http://localhost:4000/api/integrations/zoom/callback
# Optional override for Zoom OAuth scopes. These defaults match Zoom granular scopes for recording import, listing user recordings, and user lookup.
# ZOOM_SCOPES=cloud_recording:read:recording:admin,cloud_recording:read:list_user_recordings:admin,user:read:user:admin
ZOOM_WEBHOOK_SECRET=your_zoom_webhook_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CLIENT_ID=your_microsoft_app_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_app_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/integrations/teams/callback
TEAMS_WEBHOOK_SECRET=your_teams_webhook_secret

# Async process: webhook when meeting reaches ready or error (optional)
# PROCESS_WEBHOOK_URL=https://your.app/hooks/orbitplan-process
# PROCESS_WEBHOOK_SECRET=shared_secret_for_bearer_token
# Re-queue if stuck in processing longer than this (ms). Default 45 minutes.
# PROCESS_STALE_MS=2700000
